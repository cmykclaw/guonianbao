{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@guonianbao/shared": ["./shared/dist"],
      "@guonianbao/shared/*": ["./shared/dist/*"]
    },
    "references": [
      { "path": "./shared" },
      { "path": "./frontend" },
      { "path": "./backend" }
    ]
  },
  "files": [],
  "include": []
}